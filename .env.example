# Copy to .env and fill in values.
# lightsctl.sh reads .env from the project root automatically.

PI_HOST=lights.local
PI_USER=pi
PI_HOSTNAME=lights
QLC_PORT=9999

# QLC+ URL for landing page button
# Use HTTP for studio visitors (no certificate warnings)
# QLC_URL=http://lights.local:9999/
# Or use HTTPS reverse proxy if users have certificate installed
# QLC_URL=https://lights.local/qlc/

# SSH_KEY=~/.ssh/your_key

# Local directory where backups are stored
# BACKUP_STORAGE=./backups

# TLS cert/key for the ssl-proxy command (relative to project root or absolute)
# SSL_CERT=./certs/qlc.crt
# SSL_KEY=./certs/qlc.key

# Landing page branding (used by landing-setup and landing-deploy commands)
LANDING_TITLE="Lighting Controller"
LANDING_STUDIO_NAME="Your Studio"
LANDING_SUBTITLE="Lighting Controller"
LANDING_BUTTON_TEXT="Lighting Control"
LANDING_FOOTER_TEXT="lights.local"

# AI Scene Generation
# Provider: anthropic, openai, or ollama
# AI_PROVIDER=anthropic
# # API key (not needed for ollama)
# AI_API_KEY=sk-ant-...
# # Model name
# AI_MODEL=claude-3-5-sonnet-20241022


# OR for OpenAI
# AI_PROVIDER=openai
# AI_API_KEY=sk-your-openai-key
# AI_MODEL=gpt-4


# Default scene style: complete, modular, timeline, or reactive
AI_SCENE_STYLE=complete
# Default number of variations to generate
AI_SCENE_VARIATIONS=1

AI_PROVIDER=ollama
AI_MODEL=llama2